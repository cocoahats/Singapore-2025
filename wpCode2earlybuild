    function matchTier(value, tiers) {
        for (const [max, text, color] of tiers) {
            if (value <= max) return [text, color];
        }
        const fallback = tiers.at(-1);
        return [fallback?.[1] || "", fallback?.[2] || "#e6e6e6"];
